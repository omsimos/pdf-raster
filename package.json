{
  "name": "pdf-raster",
  "private": true,
  "scripts": {
    "benchmark": "bun run --cwd benchmark benchmark",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "dev": "turbo run dev",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "check-types": "turbo run check-types",
    "pdfium:download": "bun run --filter @omsimos/pdf-raster pdfium:download",
    "release:check-changeset": "bun ./scripts/check-changeset.ts",
    "release:publish": "NPM_PUBLISH_PROVENANCE=true bun ./scripts/publish-packages.ts",
    "release:publish:manual": "REQUIRE_ALL_PDFIUM_ARTIFACTS=true bun ./scripts/publish-packages.ts",
    "version-packages": "changeset version",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@changesets/cli": "^2.29.7",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^25.3.5",
    "tailwindcss": "^4.1.13",
    "turbo": "^2.8.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "benchmark",
    "docs",
    "example",
    "core"
  ]
}
