{
  "name": "@omsimos/pdf-raster",
  "version": "0.0.0",
  "description": "High-performance PDF to image conversion for Node.js and Bun.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omsimos/pdf-raster.git"
  },
  "homepage": "https://github.com/omsimos/pdf-raster#readme",
  "bugs": {
    "url": "https://github.com/omsimos/pdf-raster/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "napi": {
    "binaryName": "pdf-raster",
    "packageName": "@omsimos/pdf-raster",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "bun run build:types && bun run bundle:pdfium && bun run build:native",
    "build:debug": "bun run build:types && bun run bundle:pdfium && bun run build:native:debug",
    "build:types": "tsc -p tsconfig.json",
    "build:native": "napi build --platform --release",
    "build:native:debug": "napi build --platform",
    "create-npm-dirs": "napi create-npm-dirs --npm-dir npm",
    "collect-npm-artifacts": "napi artifacts --output-dir artifacts --npm-dir npm",
    "prepare-npm-packages": "bun ../scripts/stage-local-artifact.ts && bun run create-npm-dirs && bun run collect-npm-artifacts && bun ../scripts/copy-pdfium-to-npm.ts && napi prepublish --npm-dir npm --skip-optional-publish",
    "bundle:pdfium": "bun ../scripts/bundle-pdfium.ts",
    "clean": "bun ../scripts/clean.ts .turbo artifacts dist npm target '*.node' '*.so' '*.dylib' '*.dll'",
    "check-types": "tsc --noEmit",
    "pdfium:download": "bun ../scripts/prefetch-pdfium.ts",
    "test": "bun run build && bun run test:bun && bun run test:node",
    "test:bun": "bun test ./test",
    "test:node": "bun ./test/node-smoke.ts",
    "prepublishOnly": "bun run build && bun run prepare-npm-packages"
  },
  "keywords": [
    "pdf",
    "pdfium",
    "ocr",
    "vlm",
    "image",
    "jpeg",
    "webp",
    "png",
    "napi-rs"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^3.4.0",
    "@types/node": "^22.15.3",
    "typescript": "5.9.2"
  }
}
