{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "PDFIUM_CACHE_DIR",
    "PDFIUM_DOWNLOAD_URL",
    "PDFIUM_LIB_PATH",
    "PDFIUM_RELEASE",
    "NAPI_RS_NATIVE_LIBRARY_PATH"
  ],
  "tasks": {
    "//#format-and-lint": {},
    "//#format-and-lint:fix": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "*.node",
        "*.so",
        "*.dylib",
        "*.dll"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
