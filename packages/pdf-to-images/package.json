{
  "name": "@omsimos/pdf-to-images",
  "version": "0.0.0",
  "description": "High-performance PDF to image conversion for Node.js and Bun.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "*.node",
    "*.so",
    "*.dylib",
    "*.dll"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "napi": {
    "binaryName": "pdf-to-images",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "bun run build:types && bun run build:native",
    "build:debug": "bun run build:types && bun run build:native:debug",
    "build:types": "tsc -p tsconfig.json",
    "build:native": "napi build --platform --release",
    "build:native:debug": "napi build --platform",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "bun run build && napi prepublish -t npm"
  },
  "keywords": [
    "pdf",
    "pdfium",
    "ocr",
    "vlm",
    "image",
    "png",
    "napi-rs"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^3.4.0",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "typescript": "5.9.2"
  }
}
