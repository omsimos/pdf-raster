{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/.next",
      "!**/.turbo",
      "!**/.cache",
      "!**/coverage",
      "!**/dist",
      "!**/build",
      "!**/out",
      "!**/node_modules",
      "!**/target",
      "!**/*.node",
      "!**/*.dll",
      "!**/*.dylib",
      "!**/*.so"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
